---
// Drop into: <astro-project>/src/pages/taptallypro/index.astro
// Public URL: /taptallypro
import TapTallyProLayout from '../../layouts/TapTallyProLayout.astro';
---
<TapTallyProLayout
  title="Tap Tally — A pocket multi-counter"
  description="A quiet, ad-free multi-counter for iPhone. Reps, coffee, headcount, birds — count anything quickly. No ads. No subscription. One quiet purchase."
  variant="promo"
>
  <main>
    <section class="hero">
      <div class="hero-copy">
        <img src="/taptallypro/icon.png" alt="Tap Tally Pro icon" class="icon" />
        <h1>Tap Tally<span class="dot">.</span></h1>
        <p class="lede">A pocket multi-counter for the things that matter — and the ones that don't.</p>
        <p class="cta">
          <a class="button" href="https://apps.apple.com/us/app/tap-tally-click-counter/id6767036962" aria-label="Download Tap Tally on the App Store">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M16.365 1.43c0 1.14-.42 2.29-1.18 3.13-.78.86-2.06 1.5-3.1 1.42-.13-1.13.46-2.32 1.21-3.11.84-.9 2.27-1.55 3.07-1.44zM20.28 17.5c-.55 1.27-.81 1.83-1.51 2.95-.98 1.55-2.36 3.48-4.07 3.5-1.52.02-1.91-.97-3.97-.96-2.06.01-2.49 1-4.01.98-1.71-.02-3.02-1.77-4-3.32-2.74-4.34-3.03-9.43-1.34-12.14C3.4 6.62 5.43 5.5 7.34 5.5c1.94 0 3.16 1.04 4.77 1.04 1.56 0 2.51-1.04 4.76-1.04 1.7 0 3.5.91 4.78 2.49-4.2 2.27-3.51 8.21-1.37 9.51z"/></svg>
            Download on the App Store
          </a>
        </p>
        <a class="product-hunt-badge" href="https://www.producthunt.com/products/tap-tally-click-counter?embed=true&amp;utm_source=badge-featured&amp;utm_medium=badge&amp;utm_campaign=badge-tap-tally-click-counter" target="_blank" rel="noopener noreferrer">
          <img alt="Tap Tally - Click Counter - Count anything. Quietly. | Product Hunt" width="250" height="54" src="https://api.producthunt.com/widgets/embed-image/v1/featured.svg?post_id=1141903&amp;theme=light&amp;t=1778202479854" />
        </a>
      </div>
      <div class="phone-showcase" aria-label="Tap Tally app preview">
        <div class="iphone-frame">
          <div class="iphone-screen">
            <img src="/taptallypro/0506.gif" alt="Tap Tally counters screen in motion" />
          </div>
        </div>
      </div>
    </section>

    <hr class="hr" />

    <h2>Three things and only three things</h2>
    <ul class="features">
      <li>
        <span class="num">01</span>
        <div>
          <p class="title">Unlimited counters.</p>
          <p class="body">Reps, coffee, headcount, birds — keep as many as you like. Each with its own symbol, color, and step size.</p>
        </div>
      </li>
      <li>
        <span class="num">02</span>
        <div>
          <p class="title">No ads. Forever.</p>
          <p class="body">One quiet purchase. We don't sell your taps. We don't track you. We don't have a backend to track you with.</p>
        </div>
      </li>
      <li>
        <span class="num">03</span>
        <div>
          <p class="title">Beautiful stats.</p>
          <p class="body">Daily bar charts, a year-long heatmap, streaks, and percent-change trends. Built to be glanced at, not stared into.</p>
        </div>
      </li>
    </ul>

    <h2>What it looks like</h2>
    <div class="shots">
      <img src="/taptallypro/screenshots/02-counters.png" alt="Counter board with four labeled counters" />
      <img src="/taptallypro/screenshots/03-stats.png" alt="Stats page with bar chart and heatmap" />
      <img src="/taptallypro/screenshots/04-editor.png" alt="New counter editor" />
      <img src="/taptallypro/screenshots/01-onboarding.png" alt="Tap Tally Pro onboarding screen" />
    </div>

    <h2>Pricing</h2>
    <p><strong>$4.99 one-time.</strong> No subscription. The free tier holds 3 counters. The unlock removes the limit, opens the full stats view, and includes every future feature — widgets, Apple Watch, themes — at no extra cost.</p>

    <h2>Who it's for</h2>
    <p>Coaches counting reps. Knitters tracking stitches. Crowd counters at events. Lab workers counting cells. Birders. Bartenders. Bouncers. Anyone whose day involves saying "wait, how many was that?"</p>

    <h2>Built quietly</h2>
    <p>Tap Tally Pro is a small, single-purpose iOS app made by <a href="/">nocodehuman</a>. Local-first, native SwiftUI, no third-party SDKs. If something feels off, <a href="mailto:witchaudiodev@gmail.com">say something</a>.</p>

    <footer>
      <p>© 2026 nocodehuman · <a href="/taptallypro/privacy">Privacy</a> · <a href="/taptallypro/support">Support</a></p>
    </footer>
  </main>
</TapTallyProLayout>
