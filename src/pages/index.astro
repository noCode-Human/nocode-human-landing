      <div>
        <h3>Coming soon: the noCode Human field notes.</h3>
        <p>Short essays on agent workflows, human review, product taste, and what should stay unmistakably yours.</p>
      </div>
      <a href="#waitlist" class="btn btn-primary btn-pill">Get notified</a>
    </div>
  </section>

  <!-- WAITLIST -->
  <section class="waitlist" id="waitlist" data-od-id="waitlist">
    <div class="wrap">
      <div class="waitlist-card">
        <div class="waitlist-stripes"></div>
        <div class="section-eyebrow" style="display:inline-block;margin-bottom:18px;color:var(--accent)">// 05 — Join the waitlist</div>
        <h2>Get verified when we open the doors.</h2>
        <p>Drop your email. We'll send one short note when invites unlock — no drip campaign, no AI-written newsletter. A real human will hit send.</p>
        <form class="form" id="waitlist-form">
          <input class="input" name="email" type="email" placeholder="you@domain.com" autocomplete="email" required>
          <button class="btn btn-primary" type="submit">Join waitlist</button>
        </form>
        <div class="waitlist-status" id="waitlist-status" role="status" aria-live="polite"></div>
        <div class="waitlist-meta">2,841 builders ahead of you</div>
      </div>
    </div>
  </section>

  <!-- FOOT -->
  <footer class="foot">
    <div class="wrap">
      <div class="foot-grid">
        <div class="foot-col">
          <a class="brand" href="#"><span class="brand-mark"></span><span>noCode<span style="color:var(--muted)">/</span>Human</span></a>
          <p class="foot-tag">Build with AI. Stay human. A home for AI-assisted builders who care what their name is on.</p>
