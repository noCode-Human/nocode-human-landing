          <ul><li><a href="#apps">Apps</a></li><li><a href="#templates">Templates</a></li><li><a href="#waitlist">Get verified</a></li></ul>
        </div>
        <div class="foot-col">
          <h4>Company</h4>
          <ul><li><a href="#blog">Blog</a></li><li><a href="mailto:hello@nocodehuman.dev">Contact</a></li><li><a href="#">@nocodehuman</a></li></ul>
        </div>
      </div>
      <div class="foot-bottom">
        <span>© 2026 noCode Human · Made by humans (with help)</span>
        <span>v0.3.1 · last shipped 2026-05-06</span>
      </div>
    </div>
  </footer>

</div>
<script>
  import { ConvexHttpClient } from "convex/browser";
  import { makeFunctionReference } from "convex/server";

  const convexUrl = import.meta.env.PUBLIC_CONVEX_URL;
  const form = document.querySelector<HTMLFormElement>("#waitlist-form");
  const status = document.querySelector<HTMLElement>("#waitlist-status");
  const button = form?.querySelector<HTMLButtonElement>("button");
  const emailInput = form?.querySelector<HTMLInputElement>("input[name='email']");
  const joinWaitlist = makeFunctionReference<
    "mutation",
    { email: string; source: string },
    { status: "exists" | "joined" }
  >("waitlist:join");

  const setStatus = (message: string, tone: "success" | "error" | "muted" = "muted") => {
    if (!status) return;
    status.textContent = message;
    status.dataset.tone = tone;
  };

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();

    if (!convexUrl) {
      setStatus("Missing PUBLIC_CONVEX_URL.", "error");
      return;
    }

    if (!emailInput?.value) return;

    button?.setAttribute("disabled", "true");
    if (button) button.textContent = "Joining...";
    setStatus("Saving to Convex...");

    try {
      const client = new ConvexHttpClient(convexUrl);
      const result = await client.mutation(joinWaitlist, {
        email: emailInput.value,
        source: "landing",
      });

      emailInput.value = "";
      setStatus(
        result?.status === "exists" ? "Already on the list." : "You’re on the list.",
        "success",
      );
      if (button) button.textContent = "Joined";
    } catch (error) {
      console.error(error);
      setStatus("Couldn’t join. Try again in a minute.", "error");
      if (button) button.textContent = "Join waitlist";
    } finally {
      button?.removeAttribute("disabled");
    }
  });
</script>
</body>
</html>
