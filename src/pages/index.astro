<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/png" href="/favicon.png" />
<link rel="apple-touch-icon" href="/nocode-human-icon-192.png" />
<title>noCode Human — Build with AI. Stay human.</title>
<style>
  /* === TOKENS === */
  :root{
    --bg:#07080a;
    --surface:#101111;
    --surface-2:#16181a;
    --surface-3:#1b1c1e;
    --fg:#f9f9f9;
    --fg-2:#cecece;
    --muted:#9c9c9d;
    --muted-2:#6a6b6c;
    --border:rgba(255,255,255,0.06);
    --border-strong:rgba(255,255,255,0.10);
    --accent:#FF6363;
    --font-sans:-apple-system,BlinkMacSystemFont,"Inter","SF Pro Text","Segoe UI",system-ui,sans-serif;
    --font-mono:"JetBrains Mono","IBM Plex Mono",ui-monospace,SFMono-Regular,Menlo,monospace;
    --ring:0 0 0 1px rgb(27,28,30),inset 0 0 0 1px rgb(7,8,10);
    --ease:cubic-bezier(0.16,1,0.3,1);
    --grid:rgba(255,255,255,0.035);
  }

  /* === RESET === */
  *{box-sizing:border-box;margin:0;padding:0}
  html,body{
    background:var(--bg);color:var(--fg);
    font-family:var(--font-sans);
    font-feature-settings:"calt","kern","liga";
    -webkit-font-smoothing:antialiased;
    text-rendering:optimizeLegibility;
    letter-spacing:0.15px;
  }
  body{overflow-x:hidden}
  a{color:inherit;text-decoration:none}
  img{display:block;max-width:100%}
  ::selection{background:var(--accent);color:#000}

  /* === CANVAS === */
  .canvas{
    position:relative;
    background:
      linear-gradient(var(--grid) 1px,transparent 1px) 0 0/64px 64px,
      linear-gradient(90deg,var(--grid) 1px,transparent 1px) 0 0/64px 64px,
      var(--bg);
  }

  /* === NAV === */
  .nav{
    position:sticky;top:0;z-index:50;
    backdrop-filter:blur(12px);
    background:rgba(7,8,10,0.75);
    border-bottom:1px solid var(--border);
  }
  .nav-inner{display:flex;align-items:center;justify-content:space-between;height:64px;max-width:1200px;margin:0 auto;padding:0 24px}
  .brand{display:flex;align-items:center;gap:10px;font-weight:600;font-size:15px;letter-spacing:0.1px}
  .brand-mark{
    width:28px;height:28px;border-radius:4px;
    background:url("/nocode-human-icon-192.png") center/cover no-repeat;
    box-shadow:0 0 0 1px rgba(255,255,255,0.08),0 0 18px rgba(255,97,92,0.14);
  }
  .nav-links{display:flex;gap:28px;font-size:14px;color:var(--muted);font-weight:500}
  .nav-links a{transition:color .15s ease}
  .nav-links a:hover{color:var(--fg)}
  .nav-links .dim{color:var(--muted-2)}

  /* === BUTTONS === */
  .btn{
    display:inline-flex;align-items:center;justify-content:center;gap:8px;
    height:36px;padding:0 16px;border-radius:8px;
    font-size:14px;font-weight:600;letter-spacing:0.3px;
    border:1px solid var(--border-strong);
    background:transparent;color:var(--fg);cursor:pointer;
    transition:opacity .15s ease;
    box-shadow:inset 0 1px 0 rgba(255,255,255,0.05),inset 0 -1px 0 rgba(0,0,0,0.2),0 1px 2px rgba(0,0,0,0.3);
  }
  .btn:hover{opacity:.72}
  .btn-primary{
    background:hsla(0,0%,100%,0.92);color:#0a0a0a;border-color:transparent;
    box-shadow:inset 0 1px 0 rgba(255,255,255,0.7),inset 0 -1px 0 rgba(0,0,0,0.15),0 4px 14px rgba(255,255,255,0.08);
  }
  .btn-primary:hover{background:#fff;opacity:1}
  .btn-pill{height:34px;border-radius:999px;padding:0 14px;font-size:13px}
  .btn-lg{height:46px;padding:0 22px;font-size:15px}

  /* === SCROLL REVEAL === */
  .reveal{
    opacity:0;
    transform:translateY(44px) scale(0.982);
    transition:opacity 0.82s var(--ease),transform 0.82s var(--ease);
  }
  .reveal.visible{opacity:1;transform:translateY(0) scale(1)}
  .reveal-d1{transition-delay:0.10s}
  .reveal-d2{transition-delay:0.20s}
  .reveal-d3{transition-delay:0.30s}

  /* === HERO === */
  .hero{
    position:relative;
    min-height:100svh;
    display:flex;
    align-items:center;
    justify-content:center;
    overflow:hidden;
  }
  /* centered visual that pulses in → out → in → out → settles */
  .hero-visual{
    position:absolute;inset:0;
    display:flex;align-items:center;justify-content:center;
    pointer-events:none;
  }
  .hero-glow-bg{
    position:absolute;
    width:880px;height:880px;border-radius:50%;
    background:radial-gradient(
      closest-side,
      rgba(255,55,45,0.54),
      rgba(255,80,58,0.16) 42%,
      transparent 68%
    );
    animation:glow-pulse 3.8s ease-out forwards;
  }
  .hero-cluster{
    position:absolute;
    width:560px;height:560px;
    transform:rotate(45deg);
    border-radius:54px;
    overflow:hidden;
    animation:cluster-pulse 3.8s ease-out forwards;
  }
  .hero-cluster::before{
    content:"";position:absolute;inset:-80%;
    background:repeating-linear-gradient(
      0deg,
      rgba(175,25,25,0.72) 0px,
      rgba(255,85,68,0.97) 5px,
      rgba(210,48,46,0.80) 11px,
      rgba(24,0,0,0.22) 11px,
      rgba(24,0,0,0.22) 25px
    );
  }
  .hero-cluster::after{
    content:"";position:absolute;inset:0;
    background:radial-gradient(ellipse at center,transparent 8%,rgba(0,0,0,0.65) 76%);
  }
  @keyframes glow-pulse{
    0%  {opacity:0;transform:scale(0.52)}
    20% {opacity:1;transform:scale(1.09)}
    38% {opacity:0.06;transform:scale(0.84)}
    56% {opacity:1;transform:scale(1.12)}
    72% {opacity:0.14;transform:scale(0.93)}
    100%{opacity:0.56;transform:scale(1)}
  }
  @keyframes cluster-pulse{
    0%  {opacity:0;filter:blur(24px)}
    20% {opacity:0.9;filter:blur(0px)}
    38% {opacity:0.04;filter:blur(18px)}
    56% {opacity:0.96;filter:blur(0px)}
    72% {opacity:0.09;filter:blur(13px)}
    100%{opacity:0.52;filter:blur(3px)}
  }
  .hero-inner{
    position:relative;text-align:center;
    max-width:920px;margin:0 auto;padding:80px 24px;
  }
  .eyebrow{
    display:inline-flex;align-items:center;gap:10px;
    font-family:var(--font-mono);font-size:11px;font-weight:500;
    color:var(--muted);letter-spacing:0.5px;text-transform:uppercase;
    padding:6px 14px;border-radius:999px;border:1px solid var(--border);
    background:rgba(16,17,17,0.6);
    margin-bottom:36px;
  }
  .eyebrow .dot{width:6px;height:6px;border-radius:50%;background:var(--accent);box-shadow:0 0 10px var(--accent)}
  .h1{
    font-size:clamp(54px,9vw,120px);
    font-weight:600;line-height:1.01;
    letter-spacing:-0.03em;
    margin-bottom:28px;
  }
  .h1 em{font-style:normal;color:var(--accent)}
  .lede{
    font-size:18px;line-height:1.65;
    color:var(--fg-2);
    max-width:540px;margin:0 auto 40px;
  }
  .hero-ctas{display:flex;justify-content:center;gap:12px;flex-wrap:wrap}
  .hero-sub{
    margin-top:28px;
    display:flex;justify-content:center;gap:8px;
    font-size:13px;color:var(--muted-2);
    font-family:var(--font-mono);letter-spacing:0.3px;
  }

  /* === HERO ENTRANCE (on load, no scroll needed) === */
  @keyframes fade-up{
    from{opacity:0;transform:translateY(22px)}
    to  {opacity:1;transform:translateY(0)}
  }
  .hero-inner > *{animation:fade-up 0.82s var(--ease) both}
  .hero-inner > .eyebrow   {animation-delay:0.80s}
  .hero-inner > .h1        {animation-delay:1.05s}
  .hero-inner > .lede      {animation-delay:1.30s}
  .hero-inner > .hero-ctas {animation-delay:1.55s}
  .hero-inner > .hero-sub  {animation-delay:1.80s}

  /* === SHARED === */
  .wrap{max-width:1200px;margin:0 auto;padding:0 24px}
  .section-eyebrow{font-family:var(--font-mono);font-size:11px;font-weight:500;color:var(--muted-2);letter-spacing:0.5px;text-transform:uppercase}
  .section-label{display:flex;align-items:center;gap:14px;margin-bottom:32px;padding-bottom:16px;border-bottom:1px solid var(--border)}

  /* === LIVE PILL === */
  .live-pill{
    display:inline-flex;align-items:center;gap:7px;
    font-family:var(--font-mono);font-size:10.5px;font-weight:500;
    letter-spacing:0.5px;text-transform:uppercase;color:#5fc992;
    padding:5px 11px;border-radius:999px;
    border:1px solid rgba(95,201,146,0.22);
    background:rgba(95,201,146,0.07);
  }
  .live-dot{
    width:6px;height:6px;border-radius:50%;
    background:#5fc992;box-shadow:0 0 7px #5fc992;
    animation:pulse-live 2.4s ease-in-out infinite;
  }
  @keyframes pulse-live{
    0%,100%{opacity:1;box-shadow:0 0 7px #5fc992}
    50%{opacity:0.5;box-shadow:0 0 16px #5fc992}
  }

  /* === SOON PILL === */
  .soon-pill{
    display:inline-flex;align-items:center;gap:7px;
    font-family:var(--font-mono);font-size:10.5px;font-weight:500;
    letter-spacing:0.5px;text-transform:uppercase;color:var(--muted);
    padding:5px 11px;border-radius:999px;
    border:1px solid var(--border);
    background:rgba(255,255,255,0.025);
  }

  /* === MANIFESTO === */
  .manifesto{padding:0 0 104px}
  .manifesto-inner{
    max-width:940px;margin:0 auto;
    text-align:center;
    border-top:1px solid var(--border);
    border-bottom:1px solid var(--border);
    padding:84px 24px;
  }
  /* container just fades in fast — lines handle the movement */
  .manifesto-inner.reveal{transform:none;transition:opacity 0.5s ease}
  .manifesto h2{
    font-size:clamp(30px,4.8vw,58px);
    font-weight:600;line-height:1.07;
    letter-spacing:-0.022em;
  }
  /* line-by-line text reveal */
  .meyebrow,.mline,.mp{
    display:block;
    opacity:0;
    transform:translateY(18px);
    transition:opacity 0.7s var(--ease),transform 0.7s var(--ease);
  }
  .manifesto-inner.visible .meyebrow{opacity:1;transform:none;transition-delay:0.05s}
  .manifesto-inner.visible .mline:nth-child(1){opacity:1;transform:none;transition-delay:0.18s}
  .manifesto-inner.visible .mline:nth-child(2){opacity:1;transform:none;transition-delay:0.32s}
  .manifesto-inner.visible .mline:nth-child(3){opacity:1;transform:none;transition-delay:0.46s}
  .manifesto-inner.visible .mp{opacity:1;transform:none;transition-delay:0.60s}
  .manifesto p{margin:22px auto 0;max-width:580px;color:var(--fg-2);font-size:17px;line-height:1.7}

  /* === STORY SECTIONS (narrative below hero) === */
  .story{padding:0 0 96px;scroll-margin-top:88px}
  .story-head{margin-bottom:40px;max-width:680px}
  .story-h{
    font-size:clamp(34px,5vw,58px);
    font-weight:600;line-height:1.05;
    letter-spacing:-0.022em;
  }
  .story-h em{font-style:normal;color:var(--accent)}
  .story-sub{
    margin-top:18px;font-size:17px;
    color:var(--muted);line-height:1.62;max-width:560px;
  }

  /* tile grid (used for what it is, who it's for, why join) */
  .three-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
  .tile{
    padding:30px;border-radius:16px;
    background:var(--surface);border:1px solid var(--border);
    box-shadow:var(--ring);
    display:flex;flex-direction:column;gap:14px;
    transition:border-color .2s ease,transform .2s var(--ease);
  }
  .tile:hover{border-color:rgba(255,255,255,0.14);transform:translateY(-2px)}
  .tile-icon{
    width:38px;height:38px;border-radius:10px;
    display:grid;place-items:center;
    background:rgba(255,99,99,0.10);color:var(--accent);
    font-family:var(--font-mono);font-size:13px;font-weight:600;
    border:1px solid rgba(255,99,99,0.22);
  }
  .tile h3{font-size:19px;font-weight:600;letter-spacing:-0.01em;line-height:1.2}
  .tile p{font-size:14.5px;color:var(--muted);line-height:1.6}

  /* with/without compare grid */
  .compare-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px}
  .compare-col{
    padding:32px;border-radius:16px;
    background:var(--surface);border:1px solid var(--border);
    box-shadow:var(--ring);
  }
  .compare-col.bad{opacity:0.78}
  .compare-col h3{
    font-size:14px;font-weight:500;
    font-family:var(--font-mono);
    text-transform:uppercase;letter-spacing:0.6px;
    margin-bottom:22px;
    display:flex;align-items:center;gap:10px;
  }
  .compare-col.bad h3{color:var(--muted)}
  .compare-col.good h3{color:var(--accent)}
  .compare-col ul{list-style:none;display:flex;flex-direction:column;gap:14px}
  .compare-col li{
    font-size:15px;color:var(--fg-2);line-height:1.55;
    display:flex;gap:12px;align-items:flex-start;
  }
  .compare-col li::before{
    content:"";flex:none;
    width:7px;height:7px;border-radius:50%;
    margin-top:8px;
  }
  .compare-col.bad li::before{background:var(--muted-2)}
  .compare-col.good li::before{background:var(--accent);box-shadow:0 0 8px rgba(255,99,99,0.5)}

  /* === APPS === */
  .apps{padding:0 0 104px;scroll-margin-top:88px}
  .app-card{
    display:grid;grid-template-columns:1fr auto;
    align-items:center;gap:44px;
    padding:48px;border-radius:20px;
    background:
      radial-gradient(closest-side at 12% 16%,rgba(255,99,99,0.09),transparent 68%),
      linear-gradient(180deg,rgba(255,255,255,0.028),transparent),
      var(--surface);
    border:1px solid var(--border);
    box-shadow:var(--ring),0 48px 96px -36px rgba(0,0,0,0.7);
    text-decoration:none;
    transition:border-color .2s ease,transform .22s var(--ease),box-shadow .22s var(--ease);
  }
  .app-card:hover{
    transform:translateY(-3px);
    border-color:rgba(255,99,99,0.3);
    box-shadow:var(--ring),0 56px 100px -36px rgba(0,0,0,0.8);
  }
  .app-card-body{display:flex;flex-direction:column;gap:16px}
  .app-card h3{font-size:38px;font-weight:600;letter-spacing:-0.018em;line-height:1.06}
  .app-card p{color:var(--muted);font-size:15.5px;line-height:1.68;max-width:50ch}
  .app-cta{
    display:inline-flex;align-items:center;gap:8px;
    align-self:flex-start;
    height:38px;padding:0 18px;border-radius:999px;
    font-size:13px;font-weight:600;
    background:var(--fg);color:var(--bg);
    transition:opacity .15s ease;
  }
  .app-cta:hover{opacity:0.85}
  .app-icon-lg{
    width:164px;height:164px;border-radius:36px;
    overflow:hidden;flex:none;
    border:1px solid var(--border-strong);
    box-shadow:inset 0 1px 0 rgba(255,255,255,0.08),0 28px 60px rgba(0,0,0,0.5);
  }
  .app-icon-lg img{width:100%;height:100%;object-fit:cover}

  /* === VISION === */
  .vision{padding:0 0 104px;scroll-margin-top:88px}
  .vision-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-top:0}
  .vision-card{
    position:relative;
    padding:36px;border-radius:18px;
    background:var(--surface);
    border:1px solid var(--border);
    box-shadow:var(--ring);
    overflow:hidden;
    opacity:0.65;
  }
  .vision-card::after{
    content:"";position:absolute;inset:0;border-radius:18px;
    background:radial-gradient(closest-side at 85% 10%,rgba(255,99,99,0.05),transparent 65%);
    pointer-events:none;
  }
  .vision-card-top{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:20px;gap:16px}
  .vision-card h3{font-size:22px;font-weight:600;letter-spacing:-0.012em;line-height:1.15;margin-bottom:10px}
  .vision-card p{font-size:14px;color:var(--muted);line-height:1.68;max-width:42ch}

  /* badge stamp */
  .badge-stamp{
    position:relative;flex:none;
    width:88px;height:88px;border-radius:50%;
    background:
      radial-gradient(closest-side,rgba(255,99,99,0.14),transparent 70%),
      conic-gradient(from 90deg,var(--surface-3),var(--surface-2),var(--surface-3));
    box-shadow:var(--ring),inset 0 0 0 5px rgba(255,99,99,0.04);
    display:grid;place-items:center;
  }
  .badge-stamp::before{
    content:"";position:absolute;inset:6px;border-radius:50%;
    border:1px dashed rgba(255,99,99,0.3);
    animation:spin 36s linear infinite;
  }
  @keyframes spin{to{transform:rotate(360deg)}}
  .badge-logo-sm{position:relative;z-index:1;width:62px;height:62px;border-radius:50%;object-fit:contain}

  /* workflow list */
  .workflow-list{display:flex;flex-direction:column;gap:8px;margin-top:20px}
  .workflow-item{
    display:flex;align-items:center;gap:12px;
    padding:11px 14px;border-radius:10px;
    background:var(--surface-2);border:1px solid var(--border);
    font-size:13px;color:var(--fg-2);
  }
  .wlabel{font-family:var(--font-mono);font-size:10px;color:var(--accent);flex:none;width:18px;text-align:right}

  /* === WAITLIST === */
  .waitlist{padding:80px 0 128px;position:relative;overflow:hidden}
  .waitlist::before{
    content:"";position:absolute;inset:0;
    background:radial-gradient(closest-side at 50% 28%,rgba(255,99,99,0.07),transparent 68%);
    pointer-events:none;
  }
  .waitlist-card{
    position:relative;
    max-width:600px;margin:0 auto;
    padding:56px;text-align:center;
    background:var(--surface);
    border-radius:20px;border:1px solid var(--border);
    box-shadow:var(--ring),0 48px 96px -36px rgba(0,0,0,0.65);
  }
  .waitlist-stripes{
    position:absolute;inset:0;border-radius:20px;overflow:hidden;pointer-events:none;
    -webkit-mask-image:radial-gradient(closest-side at 50% 0%,black,transparent 58%);
            mask-image:radial-gradient(closest-side at 50% 0%,black,transparent 58%);
  }
  .waitlist-stripes::before{
    content:"";position:absolute;inset:-20%;
    background-image:repeating-linear-gradient(135deg,var(--accent) 0,var(--accent) 1.5px,transparent 1.5px,transparent 12px);
    opacity:0.18;
  }
  .waitlist h2{font-size:34px;font-weight:600;letter-spacing:-0.015em;line-height:1.1;margin-bottom:14px}
  .waitlist p{font-size:15px;color:var(--muted);margin-bottom:28px;max-width:42ch;margin-left:auto;margin-right:auto;line-height:1.62}
  .form{display:flex;gap:8px;align-items:center;justify-content:center;max-width:440px;margin:0 auto}
  .input{
    flex:1;height:46px;padding:0 16px;
    background:var(--bg);
    border:1px solid var(--border-strong);
    border-radius:10px;
    color:var(--fg);font-family:var(--font-sans);font-size:14px;
    box-shadow:inset 0 1px 0 rgba(255,255,255,0.03),inset 0 -1px 0 rgba(0,0,0,0.3);
    transition:border-color .15s ease,box-shadow .15s ease;
  }
  .input:focus{outline:none;border-color:rgba(255,99,99,0.5);box-shadow:0 0 0 3px rgba(255,99,99,0.14),inset 0 1px 0 rgba(255,255,255,0.03)}
  .input::placeholder{color:var(--muted-2)}
  .form .btn{height:46px;padding:0 22px;border-radius:10px;font-size:14px}
  .form .btn[disabled]{cursor:not-allowed;opacity:.65}
  .waitlist-meta{margin-top:18px;font-family:var(--font-mono);font-size:11px;color:var(--muted-2);letter-spacing:0.3px}
  .waitlist-status{min-height:16px;margin-top:12px;font-size:12px;color:var(--muted);font-family:var(--font-mono)}
  .waitlist-status[data-tone="success"]{color:#5fc992}
  .waitlist-status[data-tone="error"]{color:var(--accent)}

  /* === FOOTER === */
  .foot{border-top:1px solid var(--border);padding:48px 0 32px;color:var(--muted)}
  .foot-grid{display:grid;grid-template-columns:1.6fr repeat(2,1fr);gap:32px;margin-bottom:32px}
  .foot-col h4{font-size:11px;text-transform:uppercase;letter-spacing:0.4px;color:var(--muted-2);font-weight:500;margin-bottom:14px;font-family:var(--font-mono)}
  .foot-col ul{list-style:none;display:flex;flex-direction:column;gap:8px;font-size:13px}
  .foot-col a{color:var(--fg-2);transition:color .15s}
  .foot-col a:hover{color:var(--fg)}
  .foot-tag{font-size:13px;color:var(--muted);max-width:28ch;line-height:1.55;margin-top:14px}
  .foot-bottom{display:flex;justify-content:space-between;align-items:center;padding-top:24px;border-top:1px solid var(--border);font-size:12px;font-family:var(--font-mono);color:var(--muted-2);letter-spacing:0.3px}

  /* === RESPONSIVE === */
  @media(max-width:900px){
