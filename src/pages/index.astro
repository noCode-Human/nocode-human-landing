    .nav-cta .btn:not(.btn-primary){display:none}
    .hero-meta{flex-wrap:wrap;gap:8px 12px;line-height:1.3;padding:0 12px}
    .demo-header,.features-head,.quotes-head,.apps-head,.blog-head{flex-direction:column;align-items:flex-start;gap:10px}
    .features-head > .section-eyebrow{max-width:none !important;text-align:left !important}
    .feeling-inner{padding:52px 0}
    .signature .badge-stamp{width:230px;height:230px}
