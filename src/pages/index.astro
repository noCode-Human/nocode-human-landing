---
// noCode Human — homepage. The free directory of vibe-coded templates.
// Featured = this week's free drop. Grid = the whole free library.
import { items } from '../data/library';

const featured = items.find((i) => i.featured)!;
const rest = items.filter((i) => !i.featured);
const total = items.length;

// Filter chips — label + the ItemType value they match.
const filters = [
  { label: 'All', value: 'all' },
  { label: 'Apps', value: 'App' },
  { label: 'App templates', value: 'App template' },
  { label: 'Sites', value: 'Website template' },
  { label: 'Tools', value: 'Tool' },
  { label: 'Packs', value: 'Pack' },
];
---

<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/png" href="/favicon.png" />
<link rel="apple-touch-icon" href="/nocode-human-icon-192.png" />
<title>noCode Human — Free vibe-coded templates, tools & packs</title>
<meta
  name="description"
  content="noCode Human gives away a new free vibe-coded template, tool, or pack every week — apps, websites, prompts, skills. All free, all yours to fork."
/>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=Anton&family=Archivo:wght@500;600;700&display=swap"
  rel="stylesheet"
/>
<style>
  :root{
    --bg:#0a0908;
    --bg-2:#100e0c;
    --surface:#16130f;
    --surface-2:#1c1813;
    --fg:#f4efe6;
    --fg-2:#cabfae;
    --muted:#8d8473;
    --muted-2:#5f594d;
    --border:rgba(245,239,230,0.08);
    --border-strong:rgba(245,239,230,0.14);
    --accent:#ff6363;
    --amber:#e7a64d;
    --green:#b6f24a;
    --font-display:"Anton",Impact,"Arial Narrow",sans-serif;
    --font-sans:"Archivo",-apple-system,BlinkMacSystemFont,system-ui,sans-serif;
    --font-mono:"JetBrains Mono","IBM Plex Mono",ui-monospace,SFMono-Regular,Menlo,monospace;
    --ease-out:cubic-bezier(0.22,0.61,0.36,1);
  }
  *{box-sizing:border-box;margin:0;padding:0}
  html{scroll-behavior:smooth}
  body{
    background:var(--bg);color:var(--fg);
    font-family:var(--font-sans);-webkit-font-smoothing:antialiased;
    overflow-x:hidden;min-height:100vh;
  }
  a{color:inherit;text-decoration:none}
  button{font:inherit;color:inherit;background:none;border:none;cursor:pointer}
  ::selection{background:var(--accent);color:#1a0606}
  body::before{
    content:"";position:fixed;inset:0;z-index:0;pointer-events:none;
    background:
      radial-gradient(58% 44% at 78% 0%, rgba(231,166,77,0.12), transparent 70%),
      radial-gradient(46% 40% at 6% 100%, rgba(255,99,99,0.07), transparent 70%);
  }
  .wrap{max-width:1180px;margin:0 auto;padding:0 32px;position:relative;z-index:1}

  /* === NAV === */
  .nav{position:sticky;top:0;z-index:60;
    backdrop-filter:blur(14px);background:rgba(10,9,8,0.78);
    border-bottom:1px solid var(--border)}
  .nav-inner{display:flex;align-items:center;justify-content:space-between;
    height:62px;max-width:1180px;margin:0 auto;padding:0 32px}
  .brand{display:flex;align-items:center;gap:9px;font-weight:700;
    font-size:15px;letter-spacing:-0.01em}
  .brand-mark{width:24px;height:24px;border-radius:5px;flex:none;
    background:url("/nocode-human-icon-192.png") center/cover no-repeat;
    box-shadow:0 0 0 1px var(--border-strong),0 0 18px rgba(255,99,99,0.22)}
  .nav-links{display:flex;gap:26px;font-size:13.5px;color:var(--muted);font-weight:600}
  .nav-links a:hover{color:var(--fg)}
  .nav-cta{
    font-size:13px;font-weight:700;padding:9px 16px;border-radius:8px;
    background:var(--fg);color:#120d08;
    transition:transform .15s var(--ease-out),box-shadow .2s ease}
  .nav-cta:hover{transform:translateY(-1px);box-shadow:0 8px 24px rgba(244,239,230,0.14)}

  /* === HERO === */
  .hero{padding:92px 0 56px;text-align:center}
  .hero .eyebrow{
    display:inline-flex;align-items:center;gap:8px;
    font-family:var(--font-mono);font-size:11px;letter-spacing:0.18em;
    text-transform:uppercase;color:var(--accent);
    border:1px solid var(--border-strong);border-radius:999px;
    padding:7px 14px;margin-bottom:24px}
  .hero .eyebrow::before{content:"";width:6px;height:6px;border-radius:50%;
    background:var(--accent);box-shadow:0 0 8px var(--accent)}
  h1{font-family:var(--font-display);font-weight:400;
    font-size:clamp(42px,7vw,92px);line-height:0.95;
    letter-spacing:0.005em;text-transform:uppercase}
  h1 em{font-style:normal;color:var(--green)}
  .hero-sub{
    max-width:50ch;margin:22px auto 0;color:var(--fg-2);
    font-size:17px;line-height:1.6}
  .hero-actions{display:flex;gap:12px;justify-content:center;
    flex-wrap:wrap;margin-top:32px}
  .btn-primary{
    height:50px;padding:0 26px;border-radius:10px;display:inline-flex;
    align-items:center;font-weight:700;font-size:15px;
    background:var(--green);color:#0d1500;
    transition:transform .15s var(--ease-out),filter .15s ease}
  .btn-primary:hover{transform:translateY(-2px);filter:brightness(1.06)}
  .btn-ghost{
    height:50px;padding:0 22px;border-radius:10px;display:inline-flex;
    align-items:center;font-weight:700;font-size:15px;color:var(--fg-2);
    border:1px solid var(--border-strong);
    transition:color .15s ease,border-color .15s ease}
  .btn-ghost:hover{color:var(--fg);border-color:var(--fg-2)}

  /* === FEATURED — this week's free drop === */
  .featured-sec{padding:8px 0 6px}
  .featured{
    position:relative;overflow:hidden;display:grid;
    grid-template-columns:1.35fr 0.85fr;gap:36px;align-items:center;
    padding:36px 40px;border-radius:18px;
    background:linear-gradient(135deg,var(--surface-2),var(--surface));
    border:1px solid var(--border-strong);
    transition:transform .18s var(--ease-out),border-color .18s ease}
  .featured:hover{transform:translateY(-3px);border-color:rgba(182,242,74,0.4)}
  .featured::before{
    content:"";position:absolute;inset:0;pointer-events:none;
    background:radial-gradient(62% 120% at 86% 34%,
      rgba(182,242,74,0.14),transparent 70%)}
  .featured>*{position:relative}
  .ft-eyebrow{display:inline-flex;align-items:center;gap:8px;
    font-family:var(--font-mono);font-size:11px;letter-spacing:0.16em;
    text-transform:uppercase;color:var(--green);margin-bottom:13px}
  .ft-eyebrow::before{content:"";width:6px;height:6px;border-radius:50%;
    background:var(--green);box-shadow:0 0 8px var(--green)}
  .ft-name{font-family:var(--font-display);font-weight:400;
    font-size:clamp(34px,4.4vw,54px);text-transform:uppercase;
    line-height:0.96;letter-spacing:0.01em}
  .ft-tag{color:var(--fg);font-size:16.5px;font-weight:600;margin-top:9px}
  .ft-desc{color:var(--fg-2);font-size:14.5px;line-height:1.6;
    margin-top:9px;max-width:46ch}
  .ft-actions{display:flex;align-items:center;gap:16px;
    margin-top:22px;flex-wrap:wrap}
  .ft-cta{height:48px;padding:0 24px;border-radius:10px;
    display:inline-flex;align-items:center;font-weight:700;font-size:15px;
    background:var(--green);color:#0d1500}
  .featured:hover .ft-cta{filter:brightness(1.06)}
  .ft-meta{font-family:var(--font-mono);font-size:11px;
    color:var(--muted);letter-spacing:0.07em}
  .ft-visual{display:flex;justify-content:center}
  .ft-panel{
    position:relative;width:206px;height:206px;border-radius:24px;
    display:flex;flex-direction:column;align-items:center;
    justify-content:center;gap:14px;
    background:linear-gradient(150deg,rgba(182,242,74,0.22),rgba(182,242,74,0.03));
    border:1px solid rgba(182,242,74,0.32);
    box-shadow:0 24px 50px -16px rgba(0,0,0,0.85),
      0 0 64px -16px rgba(182,242,74,0.4)}
  .ft-panel svg{width:52px;height:52px;color:var(--green)}
  .ft-panel .ptype{font-family:var(--font-mono);font-size:10.5px;
    letter-spacing:0.12em;text-transform:uppercase;color:var(--green)}
  .ft-panel .pfree{position:absolute;top:13px;right:13px;
    font-family:var(--font-mono);font-size:9.5px;letter-spacing:0.1em;
    text-transform:uppercase;color:#0d1500;font-weight:700;
    background:var(--green);border-radius:5px;padding:3px 7px}

  /* === DIRECTORY === */
  .directory{padding:30px 0 80px}
  .sec-head{
    display:flex;align-items:baseline;justify-content:space-between;
    gap:20px;padding-bottom:18px;margin-bottom:20px;
    border-bottom:1px solid var(--border)}
  .sec-head h2{font-family:var(--font-display);font-weight:400;
    font-size:30px;text-transform:uppercase;letter-spacing:0.01em}
  .sec-head .count{font-family:var(--font-mono);font-size:12px;
    color:var(--muted);letter-spacing:0.1em}

  .filters{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:26px}
  .fchip{
    font-family:var(--font-mono);font-size:11.5px;letter-spacing:0.06em;
    text-transform:uppercase;padding:9px 15px;border-radius:8px;
    border:1px solid var(--border-strong);color:var(--muted);
    transition:color .15s ease,background .15s ease,border-color .15s ease}
  .fchip:hover{color:var(--fg)}
  .fchip.active{background:var(--fg);color:#120d08;border-color:var(--fg)}

  .grid{
    display:grid;gap:14px;
    grid-template-columns:repeat(auto-fill,minmax(252px,1fr))}
  .card{
    position:relative;display:flex;flex-direction:column;
    min-height:168px;padding:20px;border-radius:13px;
    background:var(--surface);border:1px solid var(--border);
    transition:transform .18s var(--ease-out),
      border-color .18s ease,background .18s ease}
  a.card:hover{
    transform:translateY(-4px);background:var(--surface-2);
    border-color:var(--border-strong)}
  .card.is-hidden{display:none}
  .card-top{display:flex;align-items:center;gap:9px;margin-bottom:14px}
  .card-dot{width:10px;height:10px;border-radius:50%;flex:none;
    background:var(--ac);box-shadow:0 0 12px -1px var(--ac)}
  .card-code{font-family:var(--font-mono);font-size:10.5px;
    color:var(--muted-2);letter-spacing:0.1em;margin-left:auto}
  .card-name{font-family:var(--font-display);font-weight:400;
    font-size:25px;text-transform:uppercase;letter-spacing:0.01em;
    line-height:1}
  .card-tag{color:var(--fg-2);font-size:14px;line-height:1.5;margin-top:9px}
  .card-foot{display:flex;align-items:center;gap:10px;margin-top:auto;
    padding-top:16px}
  .chip{font-family:var(--font-mono);font-size:10px;letter-spacing:0.07em;
    text-transform:uppercase;color:var(--muted);
    border:1px solid var(--border-strong);border-radius:6px;padding:4px 8px}
  .card-go{margin-left:auto;font-family:var(--font-mono);font-size:11px;
    letter-spacing:0.07em;color:var(--green);font-weight:700;
    text-transform:uppercase}
  .card--soon{opacity:0.6}
  .card--soon .card-go{color:var(--muted-2)}
  .grid-empty{display:none;color:var(--muted);font-size:14.5px;
    padding:30px 2px;font-family:var(--font-mono)}

  /* === NEWSLETTER === */
  .news{padding:18px 0 96px}
  .news-card{
    position:relative;overflow:hidden;border-radius:18px;
    border:1px solid var(--border-strong);background:var(--bg-2);
    padding:54px 48px;text-align:center}
  .news-card::before{
    content:"";position:absolute;inset:0;pointer-events:none;
    background:radial-gradient(60% 120% at 50% 0%,
      rgba(182,242,74,0.1),transparent 70%)}
  .news-card>*{position:relative}
  .news .eyebrow{font-family:var(--font-mono);font-size:11px;
    letter-spacing:0.2em;text-transform:uppercase;color:var(--green);
    margin-bottom:14px}
  .news-card h2{font-family:var(--font-display);font-weight:400;
    font-size:clamp(30px,4.2vw,46px);text-transform:uppercase;line-height:0.98}
  .news-card p{color:var(--fg-2);font-size:16px;line-height:1.6;
    margin:14px auto 26px;max-width:50ch}
  .form{display:flex;gap:10px;justify-content:center;flex-wrap:wrap;
    max-width:480px;margin:0 auto}
  .input{
    flex:1;min-width:220px;height:50px;padding:0 16px;border-radius:10px;
    background:var(--surface);border:1px solid var(--border-strong);
    color:var(--fg);font-size:15px;font-family:var(--font-sans)}
  .input::placeholder{color:var(--muted-2)}
  .input:focus{outline:none;border-color:var(--green)}
  .btn-join{
    height:50px;padding:0 26px;border-radius:10px;font-weight:700;
    font-size:15px;background:var(--green);color:#0d1500;
    transition:transform .15s var(--ease-out),filter .15s ease}
  .btn-join:hover{transform:translateY(-2px);filter:brightness(1.06)}
  .btn-join[disabled]{opacity:0.6;transform:none}
  .news-status{margin-top:14px;font-size:13.5px;min-height:20px;color:var(--muted)}
  .news-status[data-tone="success"]{color:var(--amber)}
  .news-status[data-tone="error"]{color:var(--accent)}
  .news-meta{margin-top:16px;font-family:var(--font-mono);font-size:11px;
    color:var(--muted-2);letter-spacing:0.07em}

  /* === FOOTER === */
  .foot{border-top:1px solid var(--border);padding:46px 0 40px}
  .foot-grid{display:flex;justify-content:space-between;gap:40px;
    flex-wrap:wrap;margin-bottom:34px}
  .foot-tag{color:var(--muted);font-size:13.5px;margin-top:12px;max-width:32ch}
  .foot-col h4{font-size:11px;font-family:var(--font-mono);
    letter-spacing:0.16em;text-transform:uppercase;color:var(--muted-2);
    margin-bottom:14px}
  .foot-col ul{list-style:none;display:flex;flex-direction:column;gap:9px}
  .foot-col a{color:var(--fg-2);font-size:14px}
  .foot-col a:hover{color:var(--fg)}
  .foot-bottom{display:flex;justify-content:space-between;gap:20px;
    flex-wrap:wrap;font-family:var(--font-mono);font-size:11px;
    color:var(--muted-2);letter-spacing:0.06em;
    padding-top:22px;border-top:1px solid var(--border)}

  @media (max-width:720px){
    .wrap,.nav-inner{padding-left:20px;padding-right:20px}
    .nav-links{display:none}
    .hero{padding:54px 0 38px}
    h1 br{display:none}
    .hero-sub{font-size:16px}
    .sec-head{flex-direction:column;align-items:flex-start;gap:7px}
    .grid{grid-template-columns:repeat(auto-fill,minmax(100%,1fr))}
    .featured{grid-template-columns:1fr;gap:22px;padding:30px 22px;text-align:center}
    .ft-eyebrow,.ft-actions{justify-content:center}
    .ft-desc{margin-left:auto;margin-right:auto}
    .ft-visual{order:-1}
    .ft-panel{width:150px;height:150px;border-radius:20px}
    .ft-panel svg{width:42px;height:42px}
    .news-card{padding:40px 22px}
  }
  @media (max-width:420px){
    .nav-cta{padding:9px 12px;font-size:12px}
  }
  @media (prefers-reduced-motion:reduce){
    *{animation-duration:0.01ms!important;transition-duration:0.01ms!important}
  }
</style>
</head>
<body>

  <nav class="nav">
    <div class="nav-inner">
      <a class="brand" href="/">
        <span class="brand-mark"></span>
        <span>noCode<span style="color:var(--muted-2)">/</span>Human</span>
      </a>
      <div class="nav-links">
        <a href="#directory">Directory</a>
        <a href="#join">Newsletter</a>
      </div>
      <a href="#join" class="nav-cta">Get the weekly drop</a>
    </div>
  </nav>

  <header class="hero">
    <div class="wrap">
      <span class="eyebrow">Free vibe-coded resources</span>
      <h1>Free vibe-coded <br/>templates &amp; <em>tools</em>.</h1>
      <p class="hero-sub">
        noCode Human gives away a new vibe-coded template, tool, or pack
        every week — apps, websites, prompts, skills. All free. All yours to fork.
      </p>
      <div class="hero-actions">
        <a href="#join" class="btn-primary">Get the weekly drop</a>
        <a href="#directory" class="btn-ghost">Browse the directory</a>
      </div>
    </div>
  </header>

  <section class="featured-sec">
    <div class="wrap">
      <a class="featured" href={featured.url} aria-label={`Get ${featured.name} free`}>
        <div>
          <span class="ft-eyebrow">This week's free drop · {featured.weekOf}</span>
          <div class="ft-name">{featured.name}</div>
          <p class="ft-tag">{featured.tag}</p>
          {featured.desc && <p class="ft-desc">{featured.desc}</p>}
          <div class="ft-actions">
            <span class="ft-cta">Get it free →</span>
            <span class="ft-meta">{featured.code} · {featured.type}</span>
          </div>
        </div>
        <div class="ft-visual">
          <div class="ft-panel">
            <span class="pfree">Free</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
              aria-hidden="true">
              <path d="M12 3v12m0 0l-4-4m4 4l4-4" />
              <path d="M4 17v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2" />
            </svg>
            <span class="ptype">{featured.type}</span>
          </div>
        </div>
      </a>
    </div>
  </section>

  <main class="directory" id="directory">
    <div class="wrap">
      <div class="sec-head">
        <h2>The directory</h2>
        <span class="count">{total} free resources · est. 2026</span>
      </div>

      <div class="filters" role="tablist">
        {filters.map((f, idx) => (
          <button
            class:list={['fchip', idx === 0 && 'active']}
            data-filter={f.value}
            type="button"
          >{f.label}</button>
        ))}
      </div>

      <div class="grid" id="grid">
        {rest.map((i) => {
          const Tag = i.live ? 'a' : 'div';
          return (
            <Tag
              class:list={['card', !i.live && 'card--soon']}
              data-type={i.type}
              href={i.live ? i.url : undefined}
              style={`--ac:${i.accent}`}
            >
              <div class="card-top">
                <span class="card-dot"></span>
                <span class="card-code">{i.code}</span>
              </div>
              <div class="card-name">{i.name}</div>
              <p class="card-tag">{i.tag}</p>
              <div class="card-foot">
                <span class="chip">{i.type}</span>
                <span class="card-go">{i.live ? 'Get it free →' : 'Soon'}</span>
              </div>
            </Tag>
          );
        })}
      </div>
      <p class="grid-empty" id="grid-empty">Nothing here yet — new drops every week.</p>
    </div>
  </main>

  <section class="news" id="join">
    <div class="wrap">
      <div class="news-card">
        <div class="eyebrow">The weekly drop</div>
        <h2>A new free template,<br/>every week.</h2>
        <p>
          One email a week with the newest free drop — a template, tool, or
          pack you can fork. No spam, no fluff. Unsubscribe anytime.
        </p>
        <form class="form" id="waitlist-form">
          <input class="input" name="email" type="email"
            placeholder="you@domain.com" autocomplete="email" required />
          <button class="btn-join" type="submit">Get the weekly drop</button>
        </form>
        <div class="news-status" id="waitlist-status" role="status" aria-live="polite"></div>
        <div class="news-meta">Every drop is free, forever. Yours to fork and ship.</div>
      </div>
    </div>
  </section>

  <footer class="foot">
    <div class="wrap">
      <div class="foot-grid">
        <div class="foot-col">
          <a class="brand" href="/"><span class="brand-mark"></span><span>noCode<span style="color:var(--muted-2)">/</span>Human</span></a>
          <p class="foot-tag">Free vibe-coded templates, tools &amp; packs. A new one every week.</p>
        </div>
        <div class="foot-col">
          <h4>Directory</h4>
          <ul>
            <li><a href="#directory">Browse all</a></li>
            <li><a href="/taptallypro">Tap Tally</a></li>
            <li><a href="/maxxtoken">MaxxToken</a></li>
            <li><a href="#join">Newsletter</a></li>
          </ul>
        </div>
        <div class="foot-col">
          <h4>Company</h4>
          <ul>
            <li><a href="mailto:hello@nocodehuman.dev">Contact</a></li>
          </ul>
        </div>
      </div>
      <div class="foot-bottom">
        <span>© 2026 noCode Human</span>
        <span>v0.7 · last shipped 2026-05-18</span>
      </div>
    </div>
  </footer>

<script>
  // === Type filters ===
  const chips = document.querySelectorAll<HTMLButtonElement>('.fchip');
  const cards = document.querySelectorAll<HTMLElement>('.card');
  const gridEmpty = document.getElementById('grid-empty');

  chips.forEach((chip) => {
    chip.addEventListener('click', () => {
      chips.forEach((c) => c.classList.remove('active'));
      chip.classList.add('active');
      const filter = chip.dataset.filter || 'all';
      let shown = 0;
      cards.forEach((card) => {
        const match = filter === 'all' || card.dataset.type === filter;
        card.classList.toggle('is-hidden', !match);
        if (match) shown += 1;
      });
      if (gridEmpty) gridEmpty.style.display = shown === 0 ? 'block' : 'none';
    });
  });

  // === Newsletter form ===
  import { ConvexHttpClient } from "convex/browser";
  import { makeFunctionReference } from "convex/server";

  const convexUrl = import.meta.env.PUBLIC_CONVEX_URL;
  const form = document.querySelector<HTMLFormElement>("#waitlist-form");
  const status = document.querySelector<HTMLElement>("#waitlist-status");
  const button = form?.querySelector<HTMLButtonElement>("button");
  const emailInput = form?.querySelector<HTMLInputElement>("input[name='email']");
  const joinWaitlist = makeFunctionReference<
    "mutation",
    { email: string; source: string },
    { status: "exists" | "joined" }
  >("waitlist:join");

  const setStatus = (message: string, tone: "success" | "error" | "muted" = "muted") => {
    if (!status) return;
    status.textContent = message;
    status.dataset.tone = tone;
  };

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    if (!convexUrl) { setStatus("Missing PUBLIC_CONVEX_URL.", "error"); return; }
    if (!emailInput?.value) return;
    button?.setAttribute("disabled", "true");
    if (button) button.textContent = "Subscribing...";
    setStatus("Saving...");
    try {
      const client = new ConvexHttpClient(convexUrl);
      const result = await client.mutation(joinWaitlist, { email: emailInput.value, source: "landing" });
      emailInput.value = "";
      setStatus(result?.status === "exists" ? "Already subscribed." : "You're in — first drop hits your inbox soon.", "success");
      if (button) button.textContent = "Subscribed";
    } catch (error) {
      console.error(error);
      setStatus("Couldn't subscribe. Try again.", "error");
      if (button) button.textContent = "Get the weekly drop";
    } finally {
      button?.removeAttribute("disabled");
    }
  });
</script>
</body>
</html>
