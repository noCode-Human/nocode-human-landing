    .app-placeholder{padding:26px}
    .app-icon{width:112px;height:112px;border-radius:24px;font-size:32px}
    .blog-card{align-items:flex-start;flex-direction:column}
    .pipeline{grid-template-columns:1fr}
    .pipe-step::after{display:none}
    .form{flex-direction:column;gap:10px}
    .form .input, .form .btn{width:100%}
    .foot-grid{grid-template-columns:1fr}
    .waitlist-card{padding:32px 24px}
    .feat{padding:24px}
  }
</style>
